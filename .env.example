# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Claude model: opus, sonnet, haiku (default: sonnet)
# CLAUDE_MODEL=sonnet

# Custom system prompt
# CLAUDE_SYSTEM_PROMPT=

# Max budget per query in USD (default: 1.0)
# CLAUDE_MAX_BUDGET=1.0

# Permission mode: default, auto (default: default)
# CLAUDE_PERMISSION_MODE=default

# Query timeout in ms (default: 600000 = 10 min)
# CLAUDE_TIMEOUT_MS=600000

# Max concurrent Claude processes (default: 3)
# CLAUDE_MAX_CONCURRENT=3

# Claude working directory — the project directory Claude Code operates in
# When set, Claude will run as if started from this directory, with access to the project's files and CLAUDE.md
# CLAUDE_WORKING_DIR=/path/to/your/project

# State directory (default: ./data)
# STATE_DIR=./data

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info
